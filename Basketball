-- Simple Hub | Rayfield Edition
-- Basketball Training Script

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local Player = Players.LocalPlayer
local Events = ReplicatedStorage:WaitForChild("Events")
local RequestServerAction = Events:WaitForChild("RequestServerAction")
local InvokeServerAction = Events:WaitForChild("InvokeServerAction")

local Toggles = {
    cash=false, train=false, rebirth=false,
    hatch=false, playrwd=false, spin=false,
    eggrwd=false, equip=false, gold=false,
}
local Connections = {}

-- Window
local Window = Rayfield:CreateWindow({
    Name = "Simple Hub",
    LoadingTitle = "Simple Hub",
    LoadingSubtitle = "Basketball Training Script",
    ConfigurationSaving = { Enabled = false },
    Discord = { Enabled = false },
    KeySystem = false,
})

-- ══════════════════════════
-- TAB: GENERAL
-- ══════════════════════════
local GeneralTab = Window:CreateTab("General", "star")

GeneralTab:CreateSection("Training")

-- Instant Cash
GeneralTab:CreateToggle({
    Name = "💰 Instant Cash",
    CurrentValue = false,
    Flag = "AutoCash",
    Callback = function(val)
        Toggles.cash = val
        if val then
            Connections.cash = task.spawn(function()
                while Toggles.cash do
                    pcall(function()
                        InvokeServerAction:InvokeServer("Win","Ended",1,999999,1)
                    end)
                    task.wait(2)
                end
            end)
        else
            Toggles.cash = false
        end
    end,
})

-- Fast Train
GeneralTab:CreateToggle({
    Name = "⚡ Fast Train",
    CurrentValue = false,
    Flag = "FastTrain",
    Callback = function(val)
        Toggles.train = val
        if val then
            Connections.train = RunService.Heartbeat:Connect(function()
                if not Toggles.train then return end
                pcall(function()
                    RequestServerAction:FireServer("Train","Increment",4,3)
                end)
            end)
        else
            if Connections.train then
                Connections.train:Disconnect()
                Connections.train = nil
            end
        end
    end,
})

-- Auto Rebirth
GeneralTab:CreateToggle({
    Name = "🔄 Auto Rebirth",
    CurrentValue = false,
    Flag = "AutoRebirth",
    Callback = function(val)
