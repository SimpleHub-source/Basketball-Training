-- Simple Hub | Baseball Training
-- Rayfield Edition

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local Player = Players.LocalPlayer
local UserId = Player.UserId

-- Remote Events
local FinishThrow = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("FinishThrow"):WaitForChild("FinishThrow")
local MakeRebirth = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("MakeRebirth"):WaitForChild("MakeRebirth")
local ReportExercise = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("ReportExerciseResult"):WaitForChild("ReportExerciseResult")

local Toggles = {
    cash = false,
    train = false,
    rebirth = false,
}
local Connections = {}

-- ══════════════════════════
-- WINDOW
-- ══════════════════════════
local Window = Rayfield:CreateWindow({
    Name = "Simple Hub",
    LoadingTitle = "Simple Hub",
    LoadingSubtitle = "Baseball Training",
    ConfigurationSaving = { Enabled = false },
    Discord = { Enabled = false },
    KeySystem = false,
})

-- ══════════════════════════
-- TAB: MAIN
-- ══════════════════════════
local MainTab = Window:CreateTab("Main", "star")

MainTab:CreateSection("General Features")

-- Instant Cash
MainTab:CreateToggle({
    Name = "💰 Instant Cash",
    CurrentValue = false,
    Flag = "AutoCash",
    Callback = function(val)
        Toggles.cash = val
        if val then
            Connections.cash = task.spawn(function()
                while Toggles.cash do
                    pcall(function()
                        FinishThrow:InvokeServer({ userId = UserId })
                    end)
                    task.wait(1)
                end
            end)
        else
            Toggles.cash = false
        end
    end,
})

-- Fast Train
MainTab:CreateToggle({
    Name = "⚡ Fast Train",
    CurrentValue = false,
    Flag = "FastTrain",
    Callback = function(val)
        Toggles.train = val
        if val then
            Connections.train = RunService.Heartbeat:Connect(function()
                if not Toggles.train then return end
                pcall(function()
                    ReportExercise:InvokeServer({
                        userId = UserId,
                        exerciseId = "exercise_3_world_1"
                    })
                end)
            end)
        else
            if Connections.train then
                Connections.train:Disconnect()
                Connections.train = nil
            end
        end
    end,
})

-- Auto Rebirth
MainTab:CreateToggle({
    Name = "🔄 Auto Rebirth",
    CurrentValue = false,
    Flag = "AutoRebirth",
    Callback = function(val)
        Toggles.rebirth = val
        if val then
            Connections.rebirth = task.spawn(function()
                while Toggles.rebirth do
                    pcall(function()
                        MakeRebirth:InvokeServer({ userId = UserId })
                    end)
                    task.wait(3)
                end
            end)
        else
            Toggles.rebirth = false
        end
    end,
})

-- ══════════════════════════
-- NOTIF
-- ══════════════════════════
Rayfield:Notify({
    Title = "Simple Hub",
    Content = "Baseball Training loaded! ⚾",
    Duration = 4,
    Image = "check",
})
