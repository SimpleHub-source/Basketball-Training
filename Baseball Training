-- Simple Hub | Baseball Training (Updated)
-- Rayfield Edition

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local Player = Players.LocalPlayer
local UserId = Player.UserId

-- Remotes
local Modules = ReplicatedStorage:WaitForChild("Modules")
local ReportExercise = Modules:WaitForChild("ReportExerciseResult"):WaitForChild("ReportExerciseResult")
local StartThrow    = Modules:WaitForChild("StartThrow"):WaitForChild("StartThrow")
local FinishThrow   = Modules:WaitForChild("FinishThrow"):WaitForChild("FinishThrow")
local MakeRebirth   = Modules:WaitForChild("MakeRebirth"):WaitForChild("MakeRebirth")

local Toggles = {
    cash    = false,
    train   = false,
    rebirth = false,
}
local Connections = {}

-- Exercise list (1-9)
local Exercises = {
    "exercise_1_world_1",
    "exercise_2_world_1",
    "exercise_3_world_1",
    "exercise_4_world_1",
    "exercise_5_world_1",
    "exercise_6_world_1",
    "exercise_7_world_1",
    "exercise_8_world_1",
    "exercise_9_world_1",
}

-- Full throw sequence (untuk instant cash)
local function DoFullThrow()
    -- Exercise 1-9
    for _, exId in ipairs(Exercises) do
        pcall(function()
            ReportExercise:InvokeServer({
                userId = UserId,
                exerciseId = exId
            })
        end)
        task.wait(0.1)
    end
    -- Start Throw
    pcall(function()
        StartThrow:InvokeServer({
            useVip = false,
            worldId = "world_1",
            userId = UserId,
            flightStartedAt = os.clock()
        })
    end)
    task.wait(0.2)
    -- Finish Throw
    pcall(function()
        FinishThrow:InvokeServer({ userId = UserId })
    end)
end

-- ══════════════════════════
-- WINDOW
-- ══════════════════════════
local Window = Rayfield:CreateWindow({
    Name = "Simple Hub",
    LoadingTitle = "Simple Hub",
    LoadingSubtitle = "Baseball Training",
    ConfigurationSaving = { Enabled = false },
    Discord = { Enabled = false },
    KeySystem = false,
})

-- ══════════════════════════
-- TAB: MAIN
-- ══════════════════════════
local MainTab = Window:CreateTab("Main", "star")

MainTab:CreateSection("General Features")

-- Instant Cash (full sequence)
MainTab:CreateToggle({
    Name = "💰 Instant Cash",
    CurrentValue = false,
    Flag = "AutoCash",
    Callback = function(val)
        Toggles.cash = val
        if val then
            Connections.cash = task.spawn(function()
                while Toggles.cash do
                    DoFullThrow()
                    task.wait(1.5)
                end
            end)
        else
            Toggles.cash = false
        end
    end,
})

-- Fast Train (fire semua exercise loop)
MainTab:CreateToggle({
    Name = "⚡ Fast Train",
    CurrentValue = false,
    Flag = "FastTrain",
    Callback = function(val)
        Toggles.train = val
        if val then
            Connections.train = task.spawn(function()
                while Toggles.train do
                    for _, exId in ipairs(Exercises) do
                        if not Toggles.train then break end
                        pcall(function()
                            ReportExercise:InvokeServer({
                                userId = UserId,
                                exerciseId = exId
                            })
                        end)
                        task.wait(0.05)
                    end
                    task.wait(0.3)
                end
            end)
        else
            Toggles.train = false
        end
    end,
})

-- Auto Rebirth
MainTab:CreateToggle({
    Name = "🔄 Auto Rebirth",
    CurrentValue = false,
    Flag = "AutoRebirth",
    Callback = function(val)
        Toggles.rebirth = val
        if val then
            Connections.rebirth = task.spawn(function()
                while Toggles.rebirth do
                    pcall(function()
                        MakeRebirth:InvokeServer({ userId = UserId })
                    end)
                    task.wait(3)
                end
            end)
        else
            Toggles.rebirth = false
        end
    end,
})

